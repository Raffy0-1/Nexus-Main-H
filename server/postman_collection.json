{
  "info": {
    "name": "Nexus API — Full Collection",
    "description": "Complete API endpoints for the Nexus Investor & Entrepreneur Collaboration Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "YOUR_JWT_TOKEN_HERE" }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"entrepreneur\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Request OTP (2FA)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/request-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP (2FA)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"RESET_TOKEN_FROM_EMAIL\",\n  \"newPassword\": \"newPassword123\"\n}"
            }
          }
        },
        {
          "name": "Change Password (Protected)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/auth/change-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newPassword456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "👤 Profile",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/profiles/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/profiles/me",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Building the future of fintech\",\n  \"title\": \"CEO & Founder\",\n  \"company\": \"TechWave Inc\",\n  \"location\": \"San Francisco, CA\",\n  \"website\": \"https://techwave.io\"\n}"
            }
          }
        },
        {
          "name": "Upload Avatar",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/profiles/me/avatar",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "avatar", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get All Investors",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/profiles/investors",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get All Entrepreneurs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/profiles/entrepreneurs",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/profiles/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "📅 Meetings",
      "item": [
        {
          "name": "Create Meeting",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/meetings",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attendeeId\": \"ATTENDEE_USER_ID\",\n  \"title\": \"Series A Discussion\",\n  \"description\": \"Discussing funding details\",\n  \"startTime\": \"2026-04-10T10:00:00Z\",\n  \"endTime\": \"2026-04-10T11:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Get My Meetings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/meetings",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Accept Meeting",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/meetings/:id/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            }
          }
        },
        {
          "name": "Reject Meeting",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/meetings/:id/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📄 Documents",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "document", "type": "file", "src": "" },
                { "key": "title", "value": "Term Sheet v1.0", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Get My Documents",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Sign Document (E-Signature)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/documents/:id/sign",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signatureUrl\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAA...\"\n}"
            }
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/documents/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "💳 Payments",
      "item": [
        {
          "name": "Deposit Funds",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/deposit",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 10000\n}"
            }
          }
        },
        {
          "name": "Withdraw Funds",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/withdraw",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"destination\": \"Chase Bank ****1234\"\n}"
            }
          }
        },
        {
          "name": "Transfer Funds",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/transfer",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25000,\n  \"destinationUserId\": \"TARGET_USER_ID\"\n}"
            }
          }
        },
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/payments/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "💬 Messages",
      "item": [
        {
          "name": "Get Conversations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/messages/conversations",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Messages with User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/messages/:userId",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/messages",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"RECEIVER_USER_ID\",\n  \"content\": \"Hello! I saw your startup profile and would love to connect.\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/notifications",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/notifications/read-all",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "🤝 Collaborations",
      "item": [
        {
          "name": "Get Collaborations",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/collaborations",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Collaboration",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/collaborations",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"partnerId\": \"PARTNER_USER_ID\",\n  \"type\": \"investment\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "Swagger Docs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api-docs"
          }
        }
      ]
    }
  ]
}
