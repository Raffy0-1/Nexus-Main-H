PORT=5000
MONGO_URI=mongodb://localhost:27017/nexus
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=30d
FRONTEND_URL=http://localhost:5173

# S3 Configuration for Document Uploads (Optional, falls back to disk space)
